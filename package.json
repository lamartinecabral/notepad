{
    "scripts": {
        "postinstall": "node scripts/update-static-files.js",
        "build": "webpack --mode=production",
        "start": "webpack server --mode=development --open --static=dist --port=8000",
        "test": "cd test && npm ci && npm run test:local",
        "serve": "python3 -m http.server -d dist",
        "deploy": "npm run build && node scripts/add-build-data.js && firebase deploy --only hosting && node scripts/add-build-data.js 0",
        "deploy:rules": "firebase deploy --only firestore:rules"
    },
    "dependencies": {
        "@codemirror/lang-cpp": "6.0.3",
        "@codemirror/lang-html": "6.4.11",
        "@codemirror/lang-java": "6.0.2",
        "@codemirror/lang-markdown": "6.5.0",
        "@codemirror/lang-python": "6.2.1",
        "@codemirror/theme-one-dark": "6.1.3",
        "codemirror": "6.0.2",
        "firebase": "12.11.0",
        "marked": "17.0.4",
        "marked-highlight": "2.2.3",
        "marked-katex-extension": "5.1.7",
        "qrcode": "1.5.4"
    },
    "devDependencies": {
        "@types/babel__standalone": "7.1.9",
        "crytop": "0.2.0",
        "firebase-tools": "15.11.0",
        "iuai": "0.9.5",
        "prettier": "3.8.1",
        "ts-loader": "9.5.4",
